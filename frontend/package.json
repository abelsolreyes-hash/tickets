{
  "name": "sistema-tickets",
  "version": "1.0.0",
  "description": "Sistema de Tickets para Informatica",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder --win portable",
    "pack": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.sistema-tickets.app",
    "productName": "Sistema Tickets",
    "directories": {
      "output": "../dist-electron-v2"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist/tickets-server.exe",
        "to": "backend/tickets-server.exe"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "src/icon.png"
    },
    "portable": {
      "artifactName": "SistemaTickets-Portable-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  }
}
